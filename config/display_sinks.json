      "resultKind": "derived_template_instantiation",
      "contextMethod": "MoveNext"
    }
  ],
  "displayVariantRules": [
    {
      "id": "noparse-confirmation-dll-labels",
      "kind": "wrap",
      "wrapper": "noparse",
      "match": "^(?:Yes, quit|Yes, I am|No, cancel)$",
      "sourceKinds": ["dll_display_flow_template"]
    },
    {
      "id": "noparse-day-ended-label",
      "kind": "wrap",
      "wrapper": "noparse",
      "match": "^DAY X ENDED$",
      "sourceKinds": ["asset_review_string"]
    },
    {
      "id": "noparse-item-description-labels",
      "kind": "wrap",
      "wrapper": "noparse",
      "sourceSet": "itemDescriptions",
      "sourceKinds": ["asset_review_string"]
    },
    {
      "id": "noparse-day-summary-dll-templates",
      "kind": "wrap",
      "wrapper": "noparse",
      "match": "^(?:Quota Excess Reward \\(\\{0\\}%\\)|Stats for day \\{0\\})$",
      "sourceKinds": ["dll_display_flow_template"]
    },
    {
      "id": "reroll-static-noparse",
      "kind": "wrap",
      "wrapper": "noparse",
      "match": "^Reroll$",
      "sourceKinds": ["asset_review_string"]
    },
    {
      "id": "reroll-static-leading-space",
      "kind": "prefix",
      "prefix": " ",
      "match": "^Reroll$",
      "sourceKinds": ["asset_review_string"]
    },
    {
      "id": "leading-space-fragment",
      "kind": "prefix",
      "prefix": " ",
      "sourceKinds": ["derived_display_fragment"],
      "maxLength": 48,
      "skipIfSourceStartsWith": ["[", "<", "\"", " "],
      "requiresTranslatableEnglish": true
    },
    {
      "id": "noparse-wrap-trusted-ui",
      "kind": "wrap",
      "wrapper": "noparse",
      "sourceKinds": ["derived_display_fragment", "dll_promoted_ldstr", "configured_display_source", "runtime_display_sink"],
      "maxLength": 220,
      "skipIfSourceStartsWith": ["<noparse"],
      "skipIfSourceContains": ["["],
      "requiresTranslatableEnglish": true
    },
    {
      "id": "rebind-label-trailing-space",
      "kind": "suffix",
      "suffix": " ",
      "sourceKinds": ["configured_display_source"],
      "maxLength": 16,
      "skipIfSourceContains": [" "]
    },
    {
      "id": "rebind-label-noparse-trailing-space",
      "kind": "wrapSuffix",
      "wrapper": "noparse",
      "suffix": " ",
      "sourceKinds": ["configured_display_source"],
      "maxLength": 16,
      "skipIfSourceContains": [" "]
    },
    {
      "id": "rainb-strip",
      "kind": "regexReplace",
      "match": "<rainb>(.*?)</rainb>",
      "replace": "$1"
    },
    {
      "id": "rainb-strip-noparse",
      "kind": "regexReplace",
      "match": "^Gives <rainb>(.*?)</rainb> item\\.$",
      "replace": "<noparse></noparse>Gives $1 item.",
      "sourceKinds": ["asset_review_string"]
    },
    {
      "id": "double-or-nothing-sign-newlines",
      "kind": "literalWhenMatch",
      "match": "^Double or nothing$",
      "literal": "Double \nor\nnothing\n\n",
      "sourceKinds": ["asset_review_string"]
    },
    {
      "id": "pay-your-debt-sign-newlines",
      "kind": "literalWhenMatch",
      "match": "^Pay your debt$",
      "literal": "Pay \nyour \ndebt\n",
      "sourceKinds": ["asset_review_string"]
    },
    {
      "id": "pay-your-debt-button-newline",
      "kind": "literalWhenMatch",
      "match": "^Pay your debt$",
      "literal": "Pay\n",
      "sourceKinds": ["asset_review_string"]
    },
    {
      "id": "reroll-challenge-newline",
      "kind": "regexLiteral",
      "match": "^Reroll Challenge \\((\\d+) Ticket\\)$",
      "literal": "Reroll Challenge \n($1 Ticket)"
    },
    {
      "id": "bet-total-template",
      "kind": "template",
      "match": "^Bet a total of .+ across all games\\.?$",
      "template": "Bet a total of {0} across all games",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "min-max-template",
      "kind": "template",
      "match": "^Min: .+(?:\\n| )Max: .+$",
      "template": "Min: {0} Max: {1}",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "buy-item-template",
      "kind": "template",
      "match": "^ ?Buy 1 Item\\(s\\) \\(.+ tickets\\)$",
      "template": " Buy 1 Item(s) ({0} tickets)",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "ticket-count-template",
      "kind": "template",
      "match": "^\\d+ Tickets$",
      "template": "{0} Tickets",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "ticket-count-singular-template",
      "kind": "template",
      "match": "^(?:[+-]\\s*)?\\d+ Ticket$",
      "template": "{0} Ticket",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "reroll-challenge-ticket-template",
      "kind": "template",
      "match": "^Reroll Challenge \\(\\d+ Ticket\\)$",
      "template": "Reroll Challenge ({0} Ticket)",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "lobby-title-template",
      "kind": "template",
      "match": "^ \\| .+'s Lobby$",
      "template": " | {0}'s Lobby",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "lobby-code-template",
      "kind": "template",
      "match": "^\\d+ \\| .+'s Lobby$",
      "template": "{0} | {1}'s Lobby",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "buy-item-interaction-template",
      "kind": "template",
      "match": "^\\[E\\] Buy 1 Item\\(s\\) \\(.+ tickets\\)$",
      "template": "[E] Buy 1 Item(s) ({0} tickets)",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "challenge-bet-template",
      "kind": "template",
      "match": "^Bet at least .+ on roulette and profit$",
      "template": "Bet at least {0} on roulette and profit",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "delete-save-template",
      "kind": "template",
      "match": "^Are you sure you want to delete the save from .+\\? This action cannot be undone\\.$",
      "template": "Are you sure you want to delete the save from {0}? This action cannot be undone.",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "day-instance-template",
      "kind": "template",
      "match": "^DAY \\d+$",
      "template": "DAY {0}",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "floor-instance-template",
      "kind": "template",
      "match": "^FLOOR \\d+$",
      "template": "FLOOR {0}",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "floor-button-instance-template",
      "kind": "template",
      "match": "^FLOOR \\d+ BUTTON$",
      "template": "FLOOR {0} BUTTON",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "stats-day-instance-template",
      "kind": "template",
      "match": "^Stats for day \\d+$",
      "template": "Stats for day {0}",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "quota-excess-template",
      "kind": "template",
      "match": "^Quota Excess Reward \\(.+%\\)$",
      "template": "Quota Excess Reward ({0}%)",
      "resultKind": "dll_display_flow_template"
    },
    {
      "id": "buy-n-items-template",
      "kind": "template",
      "match": "^ ?Buy \\d+ Item\\(s\\) \\(.+ tickets\\)$",
      "template": "Buy {0} Item(s) ({1} tickets)",
      "resultKind": "dll_display_flow_template"
    }
  ]
